import matplotlib.pyplot as plt
import numpy as np
# Data points
x = np.arange(1, 11)

# Different y datasets
y1 = x ** 2
y2 = x ** 1.5
y3 = np.log(x) * 100
y4 = x * 20

# Create the plot
plt.figure(figsize=(8,6))

# Plotting with different styles, colors, and markers
plt.plot(x, y1, 'o-', label='x^2', color='blue')          # Circle marker with line
plt.plot(x, y2, 's--', label='x^1.5', color='green')      # Square marker with dashed line
plt.plot(x, y3, 'd-.', label='log(x)*100', color='red')   # Diamond marker with dash-dot line
plt.plot(x, y4, '^:', label='x*20', color='purple')       # Triangle marker with dotted line

# Labels and title
plt.xlabel('x-axis data')
plt.ylabel('y-axis data')
plt.title('Plot with Different Colors, Line Styles, and Markers')

# Grid
plt.grid(True)

# Legend
plt.legend()

# Show the plot
plt.show()
